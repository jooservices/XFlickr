includes:
    - vendor/larastan/larastan/extension.neon
    - phpstan-baseline.neon

parameters:
    level: 6
    paths:
        - app
        - Modules/Auth
        - Modules/Crawler
        - Modules/Settings
        - Modules/Operations
        - Modules/Storage
        - Modules/Flickr
        - Modules/Contacts
        - Modules/Catalog
        - Modules/Spider
    excludePaths:
        - Modules/*/resources/*
        - Modules/*/database/*
        - Modules/*/tests/*
        - Modules/*/config/*
    stubFiles:
        - phpstan/stubs/EloquentRepository.stub
    treatPhpDocTypesAsCertain: false
