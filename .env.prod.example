APP_NAME=xflickr
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://your-server.example

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning

# Production HTTP / HTTPS (nginx)
HTTP_PORT=80
HTTPS_PORT=443
SSL_ENABLED=false
SSL_CERT_PATH=./docker/nginx/ssl-empty

# External MySQL (required)
DB_CONNECTION=mysql
DB_HOST=host.docker.internal
DB_PORT=3306
DB_DATABASE=xflickr
DB_USERNAME=xflickr
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=database

REDIS_CLIENT=phpredis
REDIS_HOST=host.docker.internal
REDIS_PASSWORD=
REDIS_PORT=6379

MAIL_MAILER=log

VITE_APP_NAME="${APP_NAME}"
INERTIA_SSR_ENABLED=false

HORIZON_NAME=xflickr-horizon
HORIZON_REPLICAS=1

FLICKR_CALLBACK_URL="${APP_URL}/flickr/callback"

MONGODB_URI=mongodb://host.docker.internal:27017
MONGODB_DATABASE=xflickr
CONFIG_STORE_CACHE_ENABLED=true
EVENTS_EVENTSOURCING_ENABLED=true
EVENTS_EVENT_LOG_ENABLED=true

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=
