        "@jooservices/react-content": "file:packages/jooservices-react-content-1.0.0.tgz",
        "@jooservices/react-layout": "file:packages/jooservices-react-layout-1.0.0.tgz",
        "@jooservices/react-modal": "file:packages/jooservices-react-modal-1.0.0.tgz",
