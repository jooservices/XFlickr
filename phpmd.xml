<?xml version="1.0"?>
<ruleset name="XFlickr"
         xmlns="https://phpmd.org/xml/ruleset/1.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="https://phpmd.org/xml/ruleset/1.0.0 https://phpmd.org/xml/ruleset_xml_schema_1.0.0.xsd">
    <description>Maintainability rules for XFlickr production PHP code.</description>

    <rule ref="rulesets/cleancode.xml">
        <!-- Laravel facades intentionally expose framework services through static proxies. -->
        <exclude name="StaticAccess"/>
    </rule>
    <rule ref="rulesets/codesize.xml"/>
    <rule ref="rulesets/design.xml"/>
    <rule ref="rulesets/unusedcode.xml"/>
</ruleset>
