<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
>
    <!--
      Suite layout mirrors XCrawlerII: one testsuite per module, pointing at
      Modules/{Name}/tests (which contains Unit/ and Feature/). Host suite owns
      tests/Unit + tests/Feature (architecture, shared app concerns). E2E stays out.
    -->
    <testsuites>
        <testsuite name="Host">
            <directory>tests/Unit</directory>
            <directory>tests/Feature</directory>
        </testsuite>
        <testsuite name="Auth">
            <directory>Modules/Auth/tests</directory>
        </testsuite>
        <testsuite name="Catalog">
            <directory>Modules/Catalog/tests</directory>
        </testsuite>
        <testsuite name="Contacts">
            <directory>Modules/Contacts/tests</directory>
        </testsuite>
        <testsuite name="Crawler">
            <directory>Modules/Crawler/tests</directory>
        </testsuite>
        <testsuite name="Flickr">
            <directory>Modules/Flickr/tests</directory>
        </testsuite>
        <testsuite name="Operations">
            <directory>Modules/Operations/tests</directory>
        </testsuite>
        <testsuite name="Settings">
            <directory>Modules/Settings/tests</directory>
        </testsuite>
        <testsuite name="Spider">
            <directory>Modules/Spider/tests</directory>
        </testsuite>
        <testsuite name="Storage">
            <directory>Modules/Storage/tests</directory>
        </testsuite>
        <testsuite name="Transfer">
            <directory>Modules/Transfer/tests</directory>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory>app</directory>
            <directory>Modules/Auth/app</directory>
            <directory>Modules/Catalog/app</directory>
            <directory>Modules/Contacts/app</directory>
            <directory>Modules/Crawler/app</directory>
            <directory>Modules/Flickr/app</directory>
            <directory>Modules/Operations/app</directory>
            <directory>Modules/Settings/app</directory>
            <directory>Modules/Spider/app</directory>
            <directory>Modules/Storage/app</directory>
            <directory>Modules/Transfer/app</directory>
        </include>
        <exclude>
            <directory>Modules/*/app/Providers</directory>
            <directory>Modules/*/database</directory>
            <directory>Modules/*/routes</directory>
            <directory>Modules/*/config</directory>
            <directory>Modules/*/resources</directory>
            <directory>app/Providers</directory>
        </exclude>
    </source>
    <php>
        <ini name="memory_limit" value="512M"/>
        <env name="APP_ENV" value="testing"/>
        <env name="APP_KEY" value="base64:+uMxrQHiSSnSC9QQV4KkDMmLjTIBbCEe5KZsCUlWuuk="/>
        <env name="APP_MAINTENANCE_DRIVER" value="file"/>
        <env name="BCRYPT_ROUNDS" value="4"/>
        <env name="BROADCAST_CONNECTION" value="null"/>
        <env name="CACHE_STORE" value="array"/>
        <env name="DB_CONNECTION" value="sqlite"/>
        <env name="DB_DATABASE" value=":memory:"/>
        <env name="DB_URL" value=""/>
        <env name="MAIL_MAILER" value="array"/>
        <env name="QUEUE_CONNECTION" value="sync"/>
        <env name="SESSION_DRIVER" value="array"/>
        <env name="PULSE_ENABLED" value="false"/>
        <env name="TELESCOPE_ENABLED" value="false"/>
        <env name="NIGHTWATCH_ENABLED" value="false"/>
        <env name="ADMIN_PASSWORD" value="password"/>
    </php>
</phpunit>
