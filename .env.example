APP_NAME=xflickr
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8082

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Dev Docker stack (docker-compose.dev.yml) — host ports when connecting from the host machine.
# Override in .env — see APP_HOST_PORT, FRONTEND_HOST_PORT, MYSQL_HOST_PORT, etc.
APP_HOST_PORT=8082
FRONTEND_HOST_PORT=5174
MYSQL_HOST_PORT=3308
REDIS_HOST_PORT=6381
MONGODB_HOST_PORT=27019
VITE_DEV_HOST=localhost
VITE_DEV_PORT=5174
MYSQL_DATABASE=xflickr
MYSQL_USER=xflickr
MYSQL_PASSWORD=secret
MYSQL_ROOT_PASSWORD=secret

# Local Docker stack — use host ports when connecting from the host machine.
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=xflickr
DB_USERNAME=xflickr
DB_PASSWORD=secret

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

# Laravel Reverb — browser connects via VITE_*; PHP publish uses REVERB_HOST/PORT
REVERB_APP_ID=xflickr-local
REVERB_APP_KEY=xflickr-local-key
REVERB_APP_SECRET=xflickr-local-secret
# Host publish target when running app on host against Docker reverb publish port:
REVERB_HOST=localhost
REVERB_PORT=8083
REVERB_SCHEME=http
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST=localhost
VITE_REVERB_PORT=8083
VITE_REVERB_SCHEME=http

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Inertia SSR (optional; disabled by default — requires a separate SSR bundle/runtime)
INERTIA_SSR_ENABLED=false

HORIZON_NAME=xflickr-horizon

FLICKR_CALLBACK_URL="${APP_URL}/flickr/callback"

MONGODB_URI=mongodb://mongodb:27017
MONGODB_DATABASE=xflickr
CONFIG_STORE_CACHE_ENABLED=true
EVENTS_EVENTSOURCING_ENABLED=true
EVENTS_EVENT_LOG_ENABLED=true

# Admin account (created by AdminUserSeeder on first Docker start)
ADMIN_EMAIL=admin@local
# Required in production. Docker generates a random password on first start when unset
# (printed once in container logs and /tmp/xflickr-admin-password).
ADMIN_PASSWORD=
# Change password anytime: php artisan xflickr:auth:reset-password admin@local
# Run manually on native installs: php artisan db:seed --class=AdminUserSeeder

# Photo download HTTP timeout (seconds) when no Settings runtime override is stored.
# XFLICKR_DOWNLOAD_TIMEOUT=120
